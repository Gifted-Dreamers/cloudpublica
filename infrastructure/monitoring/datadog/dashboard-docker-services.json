{
  "title": "Docker Services - cloudpublica.org",
  "description": "Detailed monitoring for Docker containers: Appsmith, n8n, Statamic, VVVeb, Splunk, Anytype, Snikket, AppFlowy Cloud, Nginx, Redis, PostgreSQL (docs/HOSTED-APPS)",
  "widgets": [
    {
      "definition": {
        "title": "Container Status",
        "type": "check_status",
        "check": "docker.container_health",
        "grouping": "cluster",
        "group_by": ["container_name"],
        "tags": ["env:production"]
      }
    },
    {
      "definition": {
        "title": "Appsmith (hq.cloudpublica.org)",
        "type": "group",
        "layout_type": "ordered",
        "widgets": [
          {
            "definition": {
              "title": "CPU",
              "type": "timeseries",
              "requests": [
                {
                  "q": "avg:docker.cpu.usage{container_name:appsmith}",
                  "display_type": "line"
                }
              ]
            }
          },
          {
            "definition": {
              "title": "Memory",
              "type": "timeseries",
              "requests": [
                {
                  "q": "avg:docker.mem.rss{container_name:appsmith}",
                  "display_type": "area"
                }
              ]
            }
          }
        ]
      }
    },
    {
      "definition": {
        "title": "n8n (n8n.cloudpublica.org)",
        "type": "group",
        "layout_type": "ordered",
        "widgets": [
          {
            "definition": {
              "title": "CPU",
              "type": "timeseries",
              "requests": [
                {
                  "q": "avg:docker.cpu.usage{container_name:n8n}",
                  "display_type": "line"
                }
              ]
            }
          },
          {
            "definition": {
              "title": "Memory",
              "type": "timeseries",
              "requests": [
                {
                  "q": "avg:docker.mem.rss{container_name:n8n}",
                  "display_type": "area"
                }
              ]
            }
          }
        ]
      }
    },
    {
      "definition": {
        "title": "Statamic (base.cloudpublica.org)",
        "type": "group",
        "layout_type": "ordered",
        "widgets": [
          {
            "definition": {
              "title": "CPU",
              "type": "timeseries",
              "requests": [
                {
                  "q": "avg:docker.cpu.usage{container_name:statamic}",
                  "display_type": "line"
                }
              ]
            }
          },
          {
            "definition": {
              "title": "Memory",
              "type": "timeseries",
              "requests": [
                {
                  "q": "avg:docker.mem.rss{container_name:statamic}",
                  "display_type": "area"
                }
              ]
            }
          }
        ]
      }
    },
    {
      "definition": {
        "title": "VVVeb (vvveb.cloudpublica.org)",
        "type": "group",
        "layout_type": "ordered",
        "widgets": [
          {"definition": {"title": "CPU", "type": "timeseries", "requests": [{"q": "avg:docker.cpu.usage{container_name:vvveb}", "display_type": "line"}]}},
          {"definition": {"title": "Memory", "type": "timeseries", "requests": [{"q": "avg:docker.mem.rss{container_name:vvveb}", "display_type": "area"}]}}
        ]
      }
    },
    {
      "definition": {
        "title": "Splunk (logs.cloudpublica.org)",
        "type": "group",
        "layout_type": "ordered",
        "widgets": [
          {"definition": {"title": "CPU", "type": "timeseries", "requests": [{"q": "avg:docker.cpu.usage{container_name:splunk}", "display_type": "line"}]}},
          {"definition": {"title": "Memory", "type": "timeseries", "requests": [{"q": "avg:docker.mem.rss{container_name:splunk}", "display_type": "area"}]}}
        ]
      }
    },
    {
      "definition": {
        "title": "Anytype (anytype.cloudpublica.org)",
        "type": "group",
        "layout_type": "ordered",
        "widgets": [
          {"definition": {"title": "CPU", "type": "timeseries", "requests": [{"q": "avg:docker.cpu.usage{container_name:anytype}", "display_type": "line"}]}},
          {"definition": {"title": "Memory", "type": "timeseries", "requests": [{"q": "avg:docker.mem.rss{container_name:anytype}", "display_type": "area"}]}}
        ]
      }
    },
    {
      "definition": {
        "title": "Snikket (snikket.cloudpublica.org)",
        "type": "group",
        "layout_type": "ordered",
        "widgets": [
          {"definition": {"title": "CPU", "type": "timeseries", "requests": [{"q": "avg:docker.cpu.usage{container_name:snikket}", "display_type": "line"}]}},
          {"definition": {"title": "Memory", "type": "timeseries", "requests": [{"q": "avg:docker.mem.rss{container_name:snikket}", "display_type": "area"}]}}
        ]
      }
    },
    {
      "definition": {
        "title": "AppFlowy Cloud (appflowy.cloudpublica.org)",
        "type": "group",
        "layout_type": "ordered",
        "widgets": [
          {"definition": {"title": "CPU", "type": "timeseries", "requests": [{"q": "avg:docker.cpu.usage{container_name:appflowy-cloud}", "display_type": "line"}]}},
          {"definition": {"title": "Memory", "type": "timeseries", "requests": [{"q": "avg:docker.mem.rss{container_name:appflowy-cloud}", "display_type": "area"}]}}
        ]
      }
    },
    {
      "definition": {
        "title": "Nginx Proxy",
        "type": "group",
        "layout_type": "ordered",
        "widgets": [
          {
            "definition": {
              "title": "CPU",
              "type": "timeseries",
              "requests": [
                {
                  "q": "avg:docker.cpu.usage{container_name:nginx-proxy}",
                  "display_type": "line"
                }
              ]
            }
          },
          {
            "definition": {
              "title": "Network I/O",
              "type": "timeseries",
              "requests": [
                {
                  "q": "avg:docker.net.bytes_rcvd{container_name:nginx-proxy}",
                  "display_type": "line",
                  "style": {"palette": "green"}
                },
                {
                  "q": "avg:docker.net.bytes_sent{container_name:nginx-proxy}",
                  "display_type": "line",
                  "style": {"palette": "purple"}
                }
              ]
            }
          }
        ]
      }
    },
    {
      "definition": {
        "title": "Redis Cache",
        "type": "group",
        "layout_type": "ordered",
        "widgets": [
          {
            "definition": {
              "title": "Memory Usage",
              "type": "query_value",
              "requests": [
                {
                  "q": "avg:redis.mem.used{env:production}",
                  "aggregator": "last"
                }
              ],
              "autoscale": true
            }
          },
          {
            "definition": {
              "title": "Operations/sec",
              "type": "timeseries",
              "requests": [
                {
                  "q": "avg:redis.net.commands{env:production}",
                  "display_type": "bars"
                }
              ]
            }
          }
        ]
      }
    },
    {
      "definition": {
        "title": "PostgreSQL (Billing DB)",
        "type": "group",
        "layout_type": "ordered",
        "widgets": [
          {
            "definition": {
              "title": "Connections",
              "type": "query_value",
              "requests": [
                {
                  "q": "avg:postgresql.connections{env:production}",
                  "aggregator": "last"
                }
              ],
              "precision": 0
            }
          },
          {
            "definition": {
              "title": "CPU",
              "type": "timeseries",
              "requests": [
                {
                  "q": "avg:docker.cpu.usage{container_name:billing-db}",
                  "display_type": "line"
                }
              ]
            }
          }
        ]
      }
    }
  ],
  "template_variables": [
    {
      "name": "container",
      "prefix": "container_name",
      "default": "*"
    }
  ],
  "layout_type": "ordered",
  "notify_list": []
}
