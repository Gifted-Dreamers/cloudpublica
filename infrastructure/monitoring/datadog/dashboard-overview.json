{
  "title": "Common Cloud Overview",
  "description": "Infrastructure overview for Common Cloud - Docker server (cloudpublica.org)",
  "widgets": [
    {
      "definition": {
        "title": "CPU Usage",
        "type": "timeseries",
        "requests": [
          {
            "q": "avg:system.cpu.user{env:production} by {host}",
            "display_type": "line",
            "style": {
              "palette": "dog_classic",
              "line_type": "solid",
              "line_width": "normal"
            }
          },
          {
            "q": "avg:system.cpu.system{env:production} by {host}",
            "display_type": "line",
            "style": {
              "palette": "warm",
              "line_type": "solid",
              "line_width": "normal"
            }
          }
        ],
        "yaxis": {
          "min": "0",
          "max": "100"
        }
      }
    },
    {
      "definition": {
        "title": "Memory Usage",
        "type": "timeseries",
        "requests": [
          {
            "q": "avg:system.mem.used{env:production} by {host}",
            "display_type": "area",
            "style": {
              "palette": "cool"
            }
          }
        ]
      }
    },
    {
      "definition": {
        "title": "Disk Usage",
        "type": "query_value",
        "requests": [
          {
            "q": "avg:system.disk.in_use{env:production} * 100",
            "aggregator": "avg"
          }
        ],
        "precision": 1,
        "text_align": "center",
        "custom_unit": "%"
      }
    },
    {
      "definition": {
        "title": "Docker Containers Running",
        "type": "query_value",
        "requests": [
          {
            "q": "sum:docker.containers.running{env:production}",
            "aggregator": "last"
          }
        ],
        "precision": 0,
        "text_align": "center"
      }
    },
    {
      "definition": {
        "title": "Network Traffic",
        "type": "timeseries",
        "requests": [
          {
            "q": "avg:system.net.bytes_rcvd{env:production} by {host}",
            "display_type": "line",
            "style": {
              "palette": "green"
            }
          },
          {
            "q": "avg:system.net.bytes_sent{env:production} by {host}",
            "display_type": "line",
            "style": {
              "palette": "purple"
            }
          }
        ]
      }
    },
    {
      "definition": {
        "title": "Container CPU by Service",
        "type": "timeseries",
        "requests": [
          {
            "q": "avg:docker.cpu.usage{env:production} by {container_name}",
            "display_type": "bars",
            "style": {
              "palette": "dog_classic"
            }
          }
        ]
      }
    },
    {
      "definition": {
        "title": "Container Memory by Service",
        "type": "timeseries",
        "requests": [
          {
            "q": "avg:docker.mem.rss{env:production} by {container_name}",
            "display_type": "area",
            "style": {
              "palette": "cool"
            }
          }
        ]
      }
    }
  ],
  "template_variables": [
    {
      "name": "host",
      "prefix": "host",
      "default": "*"
    },
    {
      "name": "env",
      "prefix": "env",
      "default": "production"
    }
  ],
  "layout_type": "ordered",
  "notify_list": [],
  "reflow_type": "auto"
}
